.practice-page {
  background:
    linear-gradient(180deg, rgba(230, 200, 120, 0.18), transparent 360rpx),
    #f7f3ea;
}

.loading {
  padding: 44rpx 30rpx;
  color: #66706b;
  text-align: center;
}

.question,
.editor,
.knowledge {
  padding: 32rpx 30rpx;
}

.tag {
  color: #9d2f2f;
  font-size: 24rpx;
  font-weight: 800;
}

.title {
  margin-top: 16rpx;
  color: #17211f;
  font-size: 38rpx;
  font-weight: 850;
  line-height: 1.32;
}

.title-en {
  margin-top: 12rpx;
  color: #7c8580;
  font-size: 26rpx;
  line-height: 1.5;
}

.scenario {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  color: #6f5730;
  background: rgba(230, 200, 120, 0.2);
  font-size: 26rpx;
  line-height: 1.6;
}

.editor,
.knowledge {
  margin-top: 24rpx;
}

.knowledge-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.knowledge-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  color: #5f55e8;
  background: #e8e7ff;
  font-size: 24rpx;
  font-weight: 850;
  line-height: 58rpx;
  text-align: center;
}

.knowledge-title {
  color: #17211f;
  font-size: 32rpx;
  font-weight: 850;
}

.knowledge-count {
  margin-left: auto;
  color: #9aa2ad;
  font-size: 26rpx;
}

.knowledge-empty {
  padding: 28rpx 0;
  color: #9aa2ad;
  font-size: 26rpx;
  text-align: center;
}

.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.knowledge-card {
  border: 1rpx solid rgba(31, 38, 37, 0.08);
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
}

.knowledge-card-head {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx 22rpx;
}

.chevron {
  width: 30rpx;
  color: #98a1aa;
  font-size: 42rpx;
  line-height: 42rpx;
}

.knowledge-card-text {
  min-width: 0;
  flex: 1;
}

.knowledge-card-title {
  color: #28313a;
  font-size: 30rpx;
  font-weight: 760;
  line-height: 1.4;
}

.knowledge-card-en {
  margin-top: 8rpx;
  color: #9aa2ad;
  font-size: 24rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.knowledge-body {
  padding: 0 24rpx 26rpx 70rpx;
}

.summary {
  color: #56615d;
  font-size: 25rpx;
  line-height: 1.65;
}

.knowledge-section {
  margin-top: 20rpx;
}

.section-label {
  color: #1c4a48;
  font-size: 24rpx;
  font-weight: 850;
  margin-bottom: 10rpx;
}

.warning .section-label {
  color: #9d6b17;
}

.bullet {
  color: #56615d;
  font-size: 24rpx;
  line-height: 1.6;
  margin-top: 6rpx;
}

.editor-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.editor-title {
  color: #17211f;
  font-size: 31rpx;
  font-weight: 850;
}

.counter {
  margin-top: 8rpx;
  color: #8a918e;
  font-size: 23rpx;
}

.textarea {
  width: 100%;
  min-height: 300rpx;
  margin-top: 22rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 22rpx;
  color: #1f2625;
  background: #f9f7f1;
  font-size: 29rpx;
  line-height: 1.7;
}

.textarea.en {
  font-size: 27rpx;
}

.error {
  margin-top: 22rpx;
  color: #9d2f2f;
  font-size: 26rpx;
  text-align: center;
}

.submit {
  margin-top: 24rpx;
}
