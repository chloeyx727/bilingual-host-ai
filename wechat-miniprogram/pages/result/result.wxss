.result-page {
  background:
    linear-gradient(180deg, rgba(157, 47, 47, 0.12), transparent 380rpx),
    #f7f3ea;
}

.summary {
  padding: 44rpx 34rpx;
  text-align: center;
}

.label {
  color: #9d2f2f;
  font-size: 25rpx;
  font-weight: 800;
}

.title {
  margin-top: 16rpx;
  color: #17211f;
  font-size: 34rpx;
  font-weight: 820;
  line-height: 1.35;
}

.score {
  margin-top: 26rpx;
  color: #9d2f2f;
  font-size: 96rpx;
  font-weight: 900;
  line-height: 1;
}

.score-label {
  margin-top: 8rpx;
  color: #8a918e;
  font-size: 28rpx;
}

.note {
  margin-top: 24rpx;
  color: #766a45;
  font-size: 25rpx;
  line-height: 1.55;
}

.detail {
  margin-top: 26rpx;
  padding: 32rpx;
}

.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-title {
  color: #17211f;
  font-size: 32rpx;
  font-weight: 850;
}

.pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #1c4a48;
  background: rgba(28, 74, 72, 0.12);
  font-size: 22rpx;
}

.grid {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.metric {
  padding: 22rpx 10rpx;
  border-radius: 22rpx;
  text-align: center;
  background: rgba(230, 200, 120, 0.18);
}

.metric-value {
  color: #17211f;
  font-size: 34rpx;
  font-weight: 850;
}

.metric-label {
  margin-top: 8rpx;
  color: #7e8581;
  font-size: 22rpx;
}

.advice {
  margin-top: 26rpx;
  color: #4a5350;
  font-size: 27rpx;
  line-height: 1.65;
}

button {
  margin-top: 22rpx;
}
